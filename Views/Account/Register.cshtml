@model TaskFlow.ViewModels.RegisterViewModel
@{ ViewData["Title"] = "Register"; Layout = "_Layout"; }

<div class="auth-card">
    <div class="auth-logo">
        <div class="brand-icon">
            <i class="bi bi-layers-half"></i>
        </div>
        <h1>Create account</h1>
        <p>Start managing your projects with TaskFlow</p>
    </div>

    <form asp-action="Register" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 mb-3" style="font-size:13px;border-radius:8px;"></div>

        <div class="mb-3">
            <label asp-for="FullName" class="form-label">Full name</label>
            <input asp-for="FullName" class="form-control" placeholder="Jane Doe" autocomplete="name" />
            <span asp-validation-for="FullName" class="text-danger" style="font-size:12px;"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Email" class="form-label">Email address</label>
            <input asp-for="Email" class="form-control" placeholder="you@example.com" autocomplete="email" />
            <span asp-validation-for="Email" class="text-danger" style="font-size:12px;"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Password" class="form-label">Password</label>
            <input asp-for="Password" type="password" class="form-control" placeholder="Min. 6 characters" autocomplete="new-password" />
            <span asp-validation-for="Password" class="text-danger" style="font-size:12px;"></span>
        </div>

        <div class="mb-4">
            <label asp-for="ConfirmPassword" class="form-label">Confirm password</label>
            <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="••••••••" autocomplete="new-password" />
            <span asp-validation-for="ConfirmPassword" class="text-danger" style="font-size:12px;"></span>
        </div>

        <button type="submit" class="btn btn-primary w-100">Create account <i class="bi bi-arrow-right ms-1"></i></button>
    </form>

    <p class="text-center mt-4" style="font-size:13px; color:#6b7280;">
        Already have an account? <a asp-action="Login" style="color:#6366f1; font-weight:600;">Sign in</a>
    </p>
</div>
