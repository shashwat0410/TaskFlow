@model TaskFlow.ViewModels.TaskDetailViewModel
@{ ViewData["Title"] = Model.Title; }

<div class="row g-4">
    <!-- Left: Task Detail -->
    <div class="col-lg-8">
        <div class="page-header">
            <div class="d-flex align-items-center gap-3 mb-2">
                <a asp-controller="Projects" asp-action="Details" asp-route-id="@Model.ProjectId" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left"></i></a>
                <span style="font-size:13px;color:#9ca3af;">@Model.ProjectName</span>
            </div>
            <div class="page-title">@Model.Title</div>
        </div>

        <!-- Edit Form -->
        <div class="card mb-4">
            <div class="card-header">Task Details</div>
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="ProjectId" />

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label">Title</label>
                        <input asp-for="Title" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">Description</label>
                        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-sm-6">
                            <label asp-for="Status" class="form-label">Status</label>
                            <select asp-for="Status" class="form-select"
                                    asp-items="Html.GetEnumSelectList<TaskFlow.Models.TaskStatus>()"></select>
                        </div>
                        <div class="col-sm-6">
                            <label asp-for="Priority" class="form-label">Priority</label>
                            <select asp-for="Priority" class="form-select"
                                    asp-items="Html.GetEnumSelectList<TaskFlow.Models.TaskPriority>()"></select>
                        </div>
                    </div>

                    <div class="row g-3 mb-4">
                        <div class="col-sm-6">
                            <label asp-for="DueDate" class="form-label">Due Date</label>
                            <input asp-for="DueDate" type="date" class="form-control"
                                   value="@(Model.DueDate?.ToString("yyyy-MM-dd"))" />
                        </div>
                        <div class="col-sm-6">
                            <label asp-for="AssignedToId" class="form-label">Assigned To</label>
                            <select asp-for="AssignedToId" class="form-select">
                                <option value="">— Unassigned —</option>
                                @foreach (var m in Model.ProjectMembers)
                                {
                                    if (m.UserId == Model.AssignedToId)
                                    {
                                        <option value="@m.UserId" selected="selected">@m.FullName</option>
                                    }
                                    else
                                    {
                                        <option value="@m.UserId">@m.FullName</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>

                    <div class="d-flex gap-2 justify-content-between">
                        <form asp-action="Delete" asp-route-id="@Model.Id" asp-route-projectId="@Model.ProjectId" method="post"
                              onsubmit="return confirm('Delete this task?')">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-danger btn-sm"><i class="bi bi-trash"></i> Delete</button>
                        </form>
                        <button type="submit" class="btn btn-primary btn-sm">Save Changes</button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Comments -->
        <div class="card">
            <div class="card-header">
                Comments <span class="badge bg-secondary ms-1" style="font-size:11px;">@Model.Comments.Count</span>
            </div>
            <div class="card-body p-0">
                @foreach (var comment in Model.Comments)
                {
                    <div class="d-flex gap-3 p-4 border-bottom">
                        <div class="user-avatar" style="flex-shrink:0;">
                            @comment.AuthorName.Substring(0,1).ToUpper()
                        </div>
                        <div class="flex-grow-1">
                            <div class="d-flex align-items-center gap-2 mb-1">
                                <span style="font-size:13.5px;font-weight:600;">@comment.AuthorName</span>
                                <span style="font-size:12px;color:#9ca3af;">@comment.CreatedAt.ToString("MMM dd, yyyy 'at' h:mm tt")</span>
                            </div>
                            <p style="font-size:13.5px;color:#374151;margin:0;line-height:1.6;">@comment.Content</p>
                        </div>
                    </div>
                }

                <div class="p-4">
                    <form asp-action="AddComment" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="taskId" value="@Model.Id" />
                        <div class="d-flex gap-3">
                            <div class="user-avatar" style="flex-shrink:0;">
                                @User.Identity?.Name?.Substring(0,1).ToUpper()
                            </div>
                            <div class="flex-grow-1">
                                <textarea name="content" class="form-control" rows="2"
                                          placeholder="Leave a comment..." required></textarea>
                                <button type="submit" class="btn btn-primary btn-sm mt-2">Comment</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Right: Sidebar Info -->
    <div class="col-lg-4">
        <div class="card mb-3">
            <div class="card-header">Info</div>
            <div class="card-body">
                <table class="table table-sm" style="font-size:13px;">
                    <tr>
                        <td class="text-muted" style="width:50%;">Status</td>
                        <td><span class="badge-status status-@Model.Status.ToString().ToLower()">@Model.Status</span></td>
                    </tr>
                    <tr>
                        <td class="text-muted">Priority</td>
                        <td><span class="badge-priority priority-@Model.Priority.ToString().ToLower()">@Model.Priority</span></td>
                    </tr>
                    <tr>
                        <td class="text-muted">Project</td>
                        <td><a asp-controller="Projects" asp-action="Details" asp-route-id="@Model.ProjectId" style="color:#6366f1;font-weight:600;">@Model.ProjectName</a></td>
                    </tr>
                    <tr>
                        <td class="text-muted">Assigned To</td>
                        <td>@(Model.AssignedToName ?? "Unassigned")</td>
                    </tr>
                    @if (Model.DueDate.HasValue)
                    {
                        <tr>
                            <td class="text-muted">Due Date</td>
                            <td style="color:@(Model.IsOverdue ? "#ef4444" : "inherit");">
                                @Model.DueDate.Value.ToString("MMM dd, yyyy")
                                @if (Model.IsOverdue) { <span class="text-danger">(Overdue)</span> }
                            </td>
                        </tr>
                    }
                    <tr>
                        <td class="text-muted">Created</td>
                        <td>@Model.CreatedAt.ToString("MMM dd, yyyy")</td>
                    </tr>
                </table>
            </div>
        </div>
    </div>
</div>
