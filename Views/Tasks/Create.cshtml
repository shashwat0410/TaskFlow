@model TaskFlow.ViewModels.TaskViewModel
@{ ViewData["Title"] = "New Task"; }

<div style="max-width: 600px;">
    <div class="page-header">
        <div class="d-flex align-items-center gap-3 mb-1">
            <a asp-controller="Projects" asp-action="Details" asp-route-id="@Model.ProjectId" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left"></i></a>
            <div class="page-title mb-0">New Task</div>
        </div>
        <div class="page-subtitle">in @Model.ProjectName</div>
    </div>

    <div class="card">
        <div class="card-body">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="ProjectId" />
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 mb-3" style="font-size:13px;border-radius:8px;"></div>

                <div class="mb-3">
                    <label asp-for="Title" class="form-label">Task Title *</label>
                    <input asp-for="Title" class="form-control" placeholder="What needs to be done?" autofocus />
                    <span asp-validation-for="Title" class="text-danger" style="font-size:12px;"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label">Description</label>
                    <textarea asp-for="Description" class="form-control" rows="3" placeholder="Add more details..."></textarea>
                </div>

                <div class="row g-3 mb-3">
                    <div class="col-sm-6">
                        <label asp-for="Priority" class="form-label">Priority</label>
                        <select asp-for="Priority" class="form-select"
                                asp-items="Html.GetEnumSelectList<TaskFlow.Models.TaskPriority>()"></select>
                    </div>
                    <div class="col-sm-6">
                        <label asp-for="Status" class="form-label">Status</label>
                        <select asp-for="Status" class="form-select"
                                asp-items="Html.GetEnumSelectList<TaskFlow.Models.TaskStatus>()"></select>
                    </div>
                </div>

                <div class="row g-3 mb-3">
                    <div class="col-sm-6">
                        <label asp-for="DueDate" class="form-label">Due Date</label>
                        <input asp-for="DueDate" type="date" class="form-control" />
                    </div>
                    <div class="col-sm-6">
                        <label asp-for="AssignedToId" class="form-label">Assign To</label>
                        <select asp-for="AssignedToId" class="form-select">
                            <option value="">— Unassigned —</option>
                            @if (ViewBag.Members != null)
                            {
                                foreach (var m in ViewBag.Members as List<TaskFlow.ViewModels.MemberViewModel> ?? new())
                                {
                                    <option value="@m.UserId">@m.FullName</option>
                                }
                            }
                        </select>
                    </div>
                </div>

                <div class="d-flex gap-2 justify-content-end">
                    <a asp-controller="Projects" asp-action="Details" asp-route-id="@Model.ProjectId" class="btn btn-outline-secondary">Cancel</a>
                    <button type="submit" class="btn btn-primary">Create Task</button>
                </div>
            </form>
        </div>
    </div>
</div>
