@model List<TaskFlow.ViewModels.ProjectViewModel>
@{ ViewData["Title"] = "Projects"; }

<div class="page-header d-flex align-items-center justify-content-between">
    <div>
        <div class="page-title">Projects</div>
        <div class="page-subtitle">@Model.Count project(s) total</div>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i> New Project
    </a>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-folder2-open" style="font-size:48px;color:#d1d5db;"></i>
        <h5 class="mt-3" style="color:#374151;">No projects yet</h5>
        <p class="text-muted mb-4" style="font-size:13.5px;">Create your first project to get started.</p>
        <a asp-action="Create" class="btn btn-primary">Create your first project</a>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var project in Model)
        {
            <div class="col-sm-6 col-xl-4">
                <a asp-action="Details" asp-route-id="@project.Id" class="project-card">
                    <div class="project-card-accent" style="background:@project.Color;"></div>
                    <div class="project-card-body">
                        <div class="d-flex align-items-start justify-content-between gap-2">
                            <div>
                                <div class="project-card-title">@project.Name</div>
                                @if (!string.IsNullOrEmpty(project.Description))
                                {
                                    <div class="project-card-desc mt-1">@project.Description</div>
                                }
                            </div>
                            <span class="badge-status status-@project.Status.ToString().ToLower()" style="white-space:nowrap;flex-shrink:0;">
                                @project.Status
                            </span>
                        </div>

                        <div class="project-progress">
                            <div class="progress">
                                <div class="progress-bar" style="width:@project.ProgressPercent%;background:@project.Color;"></div>
                            </div>
                            <div class="progress-label">
                                <span>@project.CompletedTasks / @project.TotalTasks tasks</span>
                                <span>@project.ProgressPercent%</span>
                            </div>
                        </div>

                        <div class="d-flex align-items-center gap-3 mt-3" style="font-size:12px;color:#9ca3af;">
                            @if (project.DueDate.HasValue)
                            {
                                <span><i class="bi bi-calendar3"></i> Due @project.DueDate.Value.ToString("MMM dd, yyyy")</span>
                            }
                            <span><i class="bi bi-person"></i> @project.OwnerName</span>
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>
}
