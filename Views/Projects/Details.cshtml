@model TaskFlow.ViewModels.ProjectViewModel
@{ ViewData["Title"] = Model.Name; }

@Html.AntiForgeryToken()

<!-- Header -->
<div class="page-header">
    <div class="d-flex align-items-center gap-3 mb-2">
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left"></i></a>
        <div style="width:14px;height:14px;border-radius:4px;background:@Model.Color;"></div>
        <div class="page-title mb-0">@Model.Name</div>
        <span class="badge-status status-@Model.Status.ToString().ToLower()">@Model.Status</span>
    </div>
    @if (!string.IsNullOrEmpty(Model.Description))
    {
        <p style="font-size:13.5px;color:#6b7280;margin:0;">@Model.Description</p>
    }
</div>

<!-- Action Bar -->
<div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
    <div class="d-flex gap-3" style="font-size:13px;color:#6b7280;">
        <span><i class="bi bi-check2-square"></i> @Model.TotalTasks tasks</span>
        <span><i class="bi bi-graph-up"></i> @Model.ProgressPercent% complete</span>
        @if (Model.DueDate.HasValue) {
            <span><i class="bi bi-calendar3"></i> Due @Model.DueDate.Value.ToString("MMM dd")</span>
        }
    </div>
    <div class="d-flex gap-2">
        <a asp-controller="Tasks" asp-action="Create" asp-route-projectId="@Model.Id" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg"></i> Add Task
        </a>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-pencil"></i> Edit
        </a>
        <form asp-action="Delete" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('Delete this project and all its tasks?')">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-outline-danger btn-sm"><i class="bi bi-trash"></i></button>
        </form>
    </div>
</div>

<!-- Progress -->
<div class="card mb-4">
    <div class="card-body py-3">
        <div class="d-flex align-items-center gap-3">
            <div class="flex-grow-1">
                <div class="progress" style="height:8px;">
                    <div class="progress-bar" style="width:@Model.ProgressPercent%;background:@Model.Color;"></div>
                </div>
            </div>
            <div style="font-size:13px;font-weight:700;color:#374151;flex-shrink:0;">@Model.ProgressPercent%</div>
        </div>
    </div>
</div>

<!-- Kanban Board -->
<div class="kanban-board">
    @{
        var statuses = new[] {
            ("Todo", "todo", "#e5e7eb"),
            ("In Progress", "inprogress", "#3b82f6"),
            ("Review", "review", "#f59e0b"),
            ("Done", "done", "#10b981")
        };
        var statusNames = new[] { "Todo", "InProgress", "Review", "Done" };
    }

    @for (int si = 0; si < statuses.Length; si++)
    {
        var (label, cls, color) = statuses[si];
        var statusName = statusNames[si];
        var statusEnum = Enum.Parse<TaskFlow.Models.TaskStatus>(statusName);
        var colTasks = Model.Tasks.Where(t => t.Status == statusEnum).ToList();

        <div class="kanban-col" data-status="@statusName">
            <div class="kanban-col-header">
                <div class="d-flex align-items-center gap-2">
                    <div style="width:8px;height:8px;border-radius:50%;background:@color;"></div>
                    <span class="kanban-col-title">@label</span>
                </div>
                <span class="kanban-count">@colTasks.Count</span>
            </div>
            <div class="kanban-tasks" id="col-@cls">
                @foreach (var task in colTasks)
                {
                    <div class="kanban-card" draggable="true" data-task-id="@task.Id">
                        <div class="kanban-card-title">@task.Title</div>
                        @if (!string.IsNullOrEmpty(task.Description))
                        {
                            <p style="font-size:12px;color:#9ca3af;margin:6px 0 0;line-height:1.5;">
                                @(task.Description.Length > 80 ? task.Description.Substring(0, 80) + "…" : task.Description)
                            </p>
                        }
                        <div class="kanban-card-meta">
                            <span class="badge-priority priority-@task.Priority.ToString().ToLower()">
                                @task.Priority
                            </span>
                            <div class="d-flex align-items-center gap-2">
                                @if (task.CommentCount > 0)
                                {
                                    <span style="font-size:11.5px;color:#9ca3af;"><i class="bi bi-chat"></i> @task.CommentCount</span>
                                }
                                @if (task.DueDate.HasValue)
                                {
                                    <span style="font-size:11.5px;color:@(task.IsOverdue ? "#ef4444" : "#9ca3af");">
                                        <i class="bi bi-calendar3"></i> @task.DueDate.Value.ToString("MMM d")
                                    </span>
                                }
                                <a asp-controller="Tasks" asp-action="Details" asp-route-id="@task.Id"
                                   style="font-size:13px;color:#9ca3af;" onclick="event.stopPropagation()">
                                    <i class="bi bi-arrow-right-circle"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>
